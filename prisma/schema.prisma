generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Parking {
  id             String   @id
  name           String
  address        String
  city           String
  insee_code     String   @db.Char(5)
  facility_type  String
  free           Boolean
  total_capacity      Int
  estimated_capacity  Int?
  disabled_spaces     Int
  ev_chargers        Int
  bike_spaces        Int
  moto_spaces        Int      @default(0)
  moto_ev_spaces     Int      @default(0)
  carsharing_spaces  Int      @default(0)
  carpool_spaces     Int      @default(0)
  max_height         Float?
  users_type         String?
  info               String?
  operator       String?
  siret          String?
  info_url       String?
  fare_url       String?
  updated_at     DateTime @updatedAt

  source         String   @default("laMetro")
  osm_id         BigInt?
  // PostGIS geometries — insert/read via $queryRaw
  position       Unsupported("geometry(Point, 4326)")?
  footprint      Unsupported("geometry(Geometry, 4326)")?

  fare           ParkingFare?
  history        ParkingHistory[]
  dailySlots     ParkingDailySlot[]

  @@map("parking")
}

model ParkingFare {
  parking_id                String   @id
  fare_1h                   Float?
  fare_2h                   Float?
  fare_3h                   Float?
  fare_4h                   Float?
  fare_24h                  Float?
  fare_disabled             Float?
  subscription_resident     Float?
  subscription_non_resident Float?
  source                    String
  updated_at                DateTime @updatedAt

  parking Parking @relation(fields: [parking_id], references: [id])

  @@map("parking_fare")
}

model ParkingHistory {
  parking_id    String
  day_of_week   Int
  slot          Int
  avg_occupancy Float
  sample_count  Int
  updated_at    DateTime @updatedAt

  parking Parking @relation(fields: [parking_id], references: [id])

  @@id([parking_id, day_of_week, slot])
  @@map("parking_history")
}

model ParkingDailySlot {
  parking_id  String
  date        String   // YYYY-MM-DD
  slot        Int      // 0-47
  occupancy   Float    // actual occupancy % at time of collection
  updated_at  DateTime @updatedAt

  parking Parking @relation(fields: [parking_id], references: [id])

  @@id([parking_id, date, slot])
  @@map("parking_daily_slot")
}

model StreetParkingZone {
  id         String @id
  name       String
  zone_color String

  // PostGIS geometry — Polygon or MultiPolygon, insert/read via $queryRaw
  geometry   Unsupported("geometry")?

  @@map("street_parking_zone")
}

model StreetParkingFareBracket {
  zone_color   String
  duration_min Int
  fare         Float
  is_penalty   Boolean @default(false)

  @@id([zone_color, duration_min])
  @@map("street_parking_fare_bracket")
}
